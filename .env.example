# Kopieer naar .env en vul in voor productie. NIET committen.

# Sterke geheime sleutels (verplicht in productie). Genereer met: openssl rand -hex 32
XPO_SECRET=
XPO_PEPPER=
XPO_PREVIEW_TTL=900

# Database: sqlite (default) of postgres
DB_DRIVER=sqlite
# PG_CONNECTION=postgres://user:pass@host:5432/dbname

# Mollie (webshop) — laat leeg voor lokale betaalstub
MOLLIE_KEY=

# Redis voor render-cache op schaal (optioneel)
# REDIS_URL=redis://localhost:6379

# CDN / assets (optioneel)
# ASSET_BASE=https://cdn.example.com
# ASSET_VER=1

# Server
PORT=3000
